# db (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/rag_db

# telegram Bot
TELEGRAM_BOT_TOKEN=token

# hugging face
HUGGINGFACE_HUB_TOKEN=token

# models
LLM_PROVIDER=openrouter
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct
LLM_MODEL_FALLBACK=Qwen/Qwen2.5-32B-Instruct
OPENROUTER_API_KEY=token
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_API_KEY=token
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL=intfloat/multilingual-e5-large
LLM_NUM_OUTPUT=2048
RERANKER_MODEL=qilowoq/bge-reranker-v2-m3-en-ru

# RAG settings
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
CONTEXT_WINDOW_SIZE=8
MAX_CONTEXT_TOKENS_EST=8000
APPROX_CHARS_PER_TOKEN=3.5

# ablation
ENABLE_LEGAL_QUERY_AGENT=true
ENABLE_ANSWER_VERIFIER=true
ENABLE_QUERY_REWRITE=true
ENABLE_RERANKER=true
ENABLE_REFERENCE_EXPANSION=true
ENABLE_FAQ_PAIR_EXPANSION=true
# full | dense_only | sparse_only | llamaindex
HYBRID_MODE=full

# app
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# /admin/*
ADMIN_API_KEY=token

# RAG relevance gate: отказ если max reranker score < порога
RAG_RELEVANCE_THRESHOLD=0.0

# explicit hybrid retrieval (sparse FTS + dense pgvector + RRF)
RAG_RETRIEVAL_MODE=llamaindex_hybrid
SPARSE_TOP_K=20
DENSE_TOP_K=20
FUSED_TOP_K=20
RRF_K=60

# retrieval metadata policy (law vs explanation)
RETRIEVAL_POLICY_TOP_K=6
LAW_BOOST=0.2
LAW_MIN=2
EXPLANATION_MIN=2

# rule-based verifier
ENABLE_RULE_BASED_VERIFIER=true

# timeouts / retries
LLM_TIMEOUT_SEC=10
RETRIEVER_TIMEOUT_SEC=10
LLM_RETRY_ATTEMPTS=3

# redis cache / rate limit
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=true
ANSWER_CACHE_TTL_SEC=300
RETRIEVAL_CACHE_TTL_SEC=120
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=100